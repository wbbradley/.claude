{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "3600000",
    "BASH_MAX_TIMEOUT_MS": "3600000"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Search",
      "WebSearch",
      "Fetch"
    ],
    "deny": [
      "Read(~/.ssh)",
      "Read(~/.sui)",
      "Read(~/.gnupg)",
      "Read(~/.password-store)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "shellsafety"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/bin/statusline.sh",
    "padding": 2
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "showClearContextOnPlanAccept": true,
  "voiceEnabled": true,
  "autoMemoryEnabled": false,
  "autoDreamEnabled": false,
  "autoMemory": false,
  "feedbackSurveyState": {
    "lastShownTime": 1855530480555
  }
}

{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "3600000",
    "BASH_MAX_TIMEOUT_MS": "3600000"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Search",
      "WebSearch",
      "Write(/tmp/*)",
      "Fetch(docs.rs)",
      "Fetch(*)"
    ],
    "deny": [
      "Read(~/.ssh)",
      "Read(~/.sui)",
      "Read(~/.gnupg)",
      "Read(~/.password-store)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "shellsafety"
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/wbbradley/src/tmux-claude/bin/tmux-claude-notify"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/wbbradley/src/tmux-claude/bin/tmux-claude-notify"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/wbbradley/src/tmux-claude/bin/tmux-claude-notify"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/wbbradley/src/tmux-claude/bin/tmux-claude-notify"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/wbbradley/src/tmux-claude/bin/tmux-claude-resume"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/wbbradley/src/tmux-claude/bin/tmux-claude-cleanup"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "statusline",
    "padding": 2
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "awaySummaryEnabled": false,
  "showClearContextOnPlanAccept": true,
  "autoMemoryEnabled": false,
  "autoDreamEnabled": false,
  "voiceEnabled": true,
  "autoMemory": false,
  "feedbackSurveyState": {
    "lastShownTime": 1855530480555
  },
  "skipAutoPermissionPrompt": true,
  "awaySummaryEnabled": false
}

{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "statusLine": {
    "type": "command",
    "command": "~/bin/statusline.sh",
    "padding": 2
  },
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "3600000",
    "BASH_MAX_TIMEOUT_MS": "3600000"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(~/.claude/skills)",
      "Read(~/.local/bin/chk)",
      "Read(/tmp/review-pr)",
      "Search(/tmp/review-pr)",
      "Read(~/.cargo)",
      "Search(~/.cargo)",
      "WebSearch"
    ],
    "deny": [
      "Read(~/.ssh)",
      "Read(~/.gnupg)",
      "Read(~/.password-store)"
    ]
  },
  "hooks": {
    "PreToolUse": [{
      "matcher": "Bash",
      "hooks": [{
        "type": "command",
        "command": "shellsafety"
      }]
    }]
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "showClearContextOnPlanAccept": true,
  "voiceEnabled": true,
  "autoMemory": false,
  "feedbackSurveyState": {
    "lastShownTime": 1855530480555
  }
}
